{
  "name": "car-gestor",
  "version": "1.0.0",
  "description": "Gestor de importacion de vehiculos",
  "main": "electron/main.js",
  "scripts": {
    "start": "concurrently --kill-others false \"npm run react-start\" \"node electron/start-server.js\" \"node electron/wait-and-launch.js\"",
    "react-start": "react-scripts start",
    "build": "react-scripts build",
    "build:desktop": "react-scripts build && electron-builder",
    "build:dir": "react-scripts build && electron-builder --dir",
    "electron": "electron .",
    "server": "node electron/start-server.js",
    "start:server": "node server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@supabase/supabase-js": "^2.108.1",
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  },
  "build": {
    "appId": "com.cargestor.app",
    "productName": "Car Gestor",
    "extends": null,
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
