# ── Servidor (backend Express) ─────────────────────────────
PORT=3001
ANTHROPIC_API_KEY=
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-x-xxx.pooler.supabase.com:6543/postgres
SUPABASE_JWT_SECRET=

# ── Frontend (React) ────────────────────────────────────────
# OJO: estas variables se incrustan en el build, hay que
# definirlas tambien como variables de entorno en Render
# (Build settings) antes de hacer "npm run build".
REACT_APP_SUPABASE_URL=https://xxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=
